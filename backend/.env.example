# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/edunovas

# Supabase Configuration (Required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Groq AI API Key (Required)
# Get your API key from: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# JWT Secret Key (Required)
# Generate a secure random string
JWT_SECRET_KEY=your_secure_jwt_secret_key_here

# Ollama Configuration (Optional - for local LLM)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:latest

# OpenAI API Key (Optional - for Supabase Studio AI features)
OPENAI_API_KEY=sk_your_openai_key_here

# S3 Configuration (Optional - for OrioleDB)
S3_HOST=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
